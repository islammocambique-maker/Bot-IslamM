{
  "version": "1.0",
  "description": "Súplicas islâmicas",
  "entries": [
    {
      "id": "dua-acordar",
      "nome": "Ao acordar",
      "contexto": "Manhã",
      "arabe": "الْحَمْدُ لِلَّهِ الَّذِي أَحْيَانَا بَعْدَ مَا أَمَاتَنَا وَإِلَيْهِ النُّشُورُ",
      "transliteracao": "Alhamdu lillahi alladhi ahyana ba'da ma amatana wa ilayhin-nushur",
      "portugues": "Louvor a Deus que nos deu vida depois da morte, e a Ele é o retorno."
    },
    {
      "id": "dua-dormir",
      "nome": "Antes de dormir",
      "contexto": "Noite",
      "arabe": "بِاسْمِكَ اللَّهُمَّ أَمُوتُ وَأَحْيَا",
      "transliteracao": "Bismika Allahumma amutu wa ahya",
      "portugues": "Em Teu nome, ó Allah, eu morro e vivo."
    },
    {
      "id": "dua-conhecimento",
      "nome": "Para conhecimento",
      "contexto": "Estudo",
      "arabe": "رَبِّ زِدْنِي عِلْمًا",
      "transliteracao": "Rabbi zidni ilma",
      "portugues": "Meu Senhor, aumenta-me em conhecimento."
    },
    {
      "id": "dua-protecao",
      "nome": "Proteção",
      "contexto": "Geral",
      "arabe": "أَعُوذُ بِاللَّهِ مِنَ الشَّيْطَانِ الرَّجِيمِ",
      "transliteracao": "A'udhu billahi minash-shaytanir-rajim",
      "portugues": "Busco proteção em Deus contra Satanás, o condenado."
    },
    {
      "id": "dua-pais",
      "nome": "Para os pais",
      "contexto": "Gratidão",
      "arabe": "رَبِّ ارْحَمْهُمَا كَمَا رَبَّيَانِي صَغِيرًا",
      "transliteracao": "Rabbi irhamhuma kama rabbayani saghira",
      "portugues": "Meu Senhor, tem misericórdia deles, como me criaram quando pequeno."
    }
  ]
}
